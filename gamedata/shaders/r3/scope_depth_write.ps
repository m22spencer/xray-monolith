#include "common.h"

// Add to surface depth to handle precision issues
#define EPSILON 0.001f

// If >= 0, write a specific fixed depth
//   used for setting near and far rendering distance
uniform float scope_depth_value;

struct vf {
    float4 hpos : SV_Position;
    float2 tc0  : TEXCOORD0;
};

struct PSOutput
{
	float depth : SV_Depth; // TODO: Change to SV_DepthGreaterEqual
};

PSOutput main(vf i)
{
	PSOutput output;

    output.depth = scope_depth_value < 0 
        ? i.hpos.z + EPSILON
        : scope_depth_value;
	return output;
}